{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://erlvinc.com/schemas/run-spec.json",
  "title": "Run Specification",
  "description": "Defines a bounded execution task for the Ralph Loop autonomous execution engine",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "project_id",
    "task_type",
    "risk_level",
    "objective",
    "repo",
    "branch",
    "allowed_paths",
    "forbidden_paths",
    "acceptance_criteria",
    "commands",
    "deliverables",
    "stop_conditions",
    "max_turns"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0",
      "description": "Schema version for validation"
    },
    "run_id": {
      "type": "string",
      "pattern": "^run_[0-9]{4}_[0-9]{2}_[0-9]{2}_[0-9]{3}$",
      "description": "Unique run identifier (format: run_YYYY_MM_DD_NNN)"
    },
    "project_id": {
      "type": "string",
      "minLength": 1,
      "description": "Project identifier"
    },
    "task_type": {
      "type": "string",
      "enum": ["implementation", "bugfix", "refactor", "docs", "migration", "audit"],
      "description": "Type of task being executed"
    },
    "risk_level": {
      "type": "string",
      "enum": ["low", "medium", "high", "critical"],
      "description": "Risk level determining approval requirements"
    },
    "objective": {
      "type": "string",
      "minLength": 10,
      "maxLength": 500,
      "description": "Clear description of what this run should accomplish"
    },
    "repo": {
      "type": "object",
      "required": ["url", "base_branch"],
      "properties": {
        "url": {
          "type": "string",
          "pattern": "^(git@|https://)",
          "description": "Git repository URL"
        },
        "base_branch": {
          "type": "string",
          "default": "main",
          "description": "Base branch to branch from"
        }
      }
    },
    "branch": {
      "type": "string",
      "pattern": "^agent/run_[0-9]{4}_[0-9]{2}_[0-9]{2}_[0-9]{3}$",
      "description": "Git branch for this run"
    },
    "allowed_paths": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1,
      "description": "Glob patterns for files that may be modified"
    },
    "forbidden_paths": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Glob patterns for files that must never be modified"
    },
    "required_inputs": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Files that must be read before execution"
    },
    "acceptance_criteria": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1,
      "description": "Conditions that must be met for run completion"
    },
    "commands": {
      "type": "object",
      "properties": {
        "install": {
          "type": "string",
          "description": "Command to install dependencies"
        },
        "lint": {
          "type": "string",
          "description": "Command to run linting"
        },
        "typecheck": {
          "type": "string",
          "description": "Command to run type checking"
        },
        "test": {
          "type": "string",
          "description": "Command to run tests"
        },
        "smoke": {
          "type": "string",
          "description": "Command to run smoke tests"
        },
        "deploy_dry": {
          "type": "string",
          "description": "Command to run dry-run deployment"
        }
      },
      "description": "Commands for quality gates"
    },
    "deliverables": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["code_changes", "tests", "docs_update", "run_report", "migration", "config_changes"]
      },
      "minItems": 1,
      "description": "Expected deliverables from this run"
    },
    "stop_conditions": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Conditions that should halt execution"
    },
    "human_approval_required_for": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Actions that require human approval"
    },
    "max_turns": {
      "type": "integer",
      "minimum": 5,
      "maximum": 100,
      "default": 25,
      "description": "Maximum number of turns before forced stop"
    },
    "model": {
      "type": "string",
      "default": "claude-sonnet-4-5-20250929",
      "description": "Model to use for execution"
    }
  },
  "additionalProperties": false
}
