{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://erlvinc.com/schemas/doc-manifest.json",
  "title": "Document Manifest",
  "description": "Defines required and optional documents for a Ralph Loop execution",
  "type": "object",
  "required": ["version", "project", "documents"],
  "properties": {
    "version": {
      "type": "string",
      "const": "1.0",
      "description": "Manifest version"
    },
    "project": {
      "type": "string",
      "description": "Project identifier"
    },
    "documents": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "path", "priority", "required", "summary"],
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique document identifier"
          },
          "path": {
            "type": "string",
            "description": "Path to the document relative to project root"
          },
          "priority": {
            "type": "integer",
            "minimum": 1,
            "maximum": 10,
            "description": "Priority for reading order (1 = highest)"
          },
          "required": {
            "type": "boolean",
            "description": "Whether this document must be read in full"
          },
          "summary": {
            "type": "string",
            "maxLength": 200,
            "description": "Brief summary of document contents"
          }
        }
      },
      "description": "List of documents to include in context"
    }
  },
  "additionalProperties": false
}
